{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "lyse",
  "homepage": "https://ui.lyse.dev",
  "items": [
    {
      "name": "lyse-tokens",
      "type": "registry:style",
      "description": "Lyse Design System tokens — required foundation for all Lyse components. Includes color primitives, semantic colors (light/dark), layout tokens, typography tokens, and shadcn bridge.",
      "files": [
        {
          "path": "app/styles/root-colors.css",
          "type": "registry:file",
          "target": "~/styles/lyse/root-colors.css"
        },
        {
          "path": "app/styles/root-typography.css",
          "type": "registry:file",
          "target": "~/styles/lyse/root-typography.css"
        },
        {
          "path": "app/styles/root-layout.css",
          "type": "registry:file",
          "target": "~/styles/lyse/root-layout.css"
        },
        {
          "path": "app/styles/semantic-global.css",
          "type": "registry:file",
          "target": "~/styles/lyse/semantic-global.css"
        },
        {
          "path": "app/styles/semantic-colors.css",
          "type": "registry:file",
          "target": "~/styles/lyse/semantic-colors.css"
        },
        {
          "path": "app/styles/shadcn-bridge.css",
          "type": "registry:file",
          "target": "~/styles/lyse/shadcn-bridge.css"
        },
        {
          "path": "app/styles/typography.css",
          "type": "registry:file",
          "target": "~/styles/lyse/typography.css"
        }
      ],
      "docs": "After installing, import all token files in your main CSS entry point (e.g. globals.css):\n\n@import './styles/lyse/root-colors.css';\n@import './styles/lyse/root-typography.css';\n@import './styles/lyse/root-layout.css';\n@import './styles/lyse/semantic-global.css';\n@import './styles/lyse/semantic-colors.css';\n@import './styles/lyse/shadcn-bridge.css';\n@import './styles/lyse/typography.css';\n\nFor dark mode, add the 'dark' class to your HTML root element."
    },
